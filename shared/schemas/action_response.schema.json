  "description": "Response to a screen action (POST to ActionDef.endpoint).\n\nNavigation priority when multiple fields are set (only one should be): 1. redirect_url — clears history, navigates to URL 2. push_url     — pushes URL onto stack 3. screen       — replaces current screen inline 4. (none)       — client refreshes current URL\n\nOn failure (success: false), all navigation fields are ignored.",
  "properties": {
    "error": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "message": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "push_url": {
      "default": null,
      "description": "Pushes this URL onto the navigation stack. Use for non-destructive redirects (e.g. print preview, report). Escape returns to the current screen naturally.",
      "type": [
        "string",
        "null"
      ]
    },
    "redirect_url": {
      "default": null,
      "description": "Clears navigation history and navigates to this URL. Use when an action transforms the record into something else (e.g. posting an invoice). Escape from the destination is handled by that screen's parent_url.",
      "type": [
        "string",
        "null"
      ]
    },
    "screen": {
      "anyOf": [
        {
          "$ref": "#/definitions/ScreenContract"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Replaces the current screen inline. Lower priority than redirect_url/push_url."
    },
    "success": {
      "type": "boolean"
    }
  },
  "required": [
    "success"
  ],
